# Text model. The UI can write these values for you.
LLM_PROVIDER=custom
LLM_MODEL=qwen-plus
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=replace_with_your_api_key
LLM_TEMPERATURE=0.2

# Application behavior.
APP_LANGUAGE=zh
MAX_SEARCH_RESULTS=5
FINALS_AGENT_DEBUG=false
PLANNER_PROVIDER=hybrid
PLANNER_CONFIDENCE_THRESHOLD=0.80

# Embeddings stay independent from the text model. DeepSeek embeddings are
# intentionally not configured; leave disabled until a Qwen API integration
# or an explicit local embedding setup is added.
EMBEDDING_PROVIDER=disabled
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
# EMBEDDING_DEVICE=cpu

# Optional OpenAI-compatible vision endpoint.
VISION_PROVIDER=disabled
# VISION_PROVIDER=openai_compatible
# VISION_MODEL=qwen-vl-max
# VISION_API_KEY=replace_with_your_vision_api_key
# VISION_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
VISION_RENDER_DPI=180
VISION_TIMEOUT_SECONDS=60

# Optional DocLayout-YOLO fallback using an existing environment with Torch.
# DOCLAYOUT_PYTHON=D:\path\to\conda\env\python.exe
# DOCLAYOUT_DEVICE=cuda:0

# Optional LangSmith tracing.
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=replace_with_your_langsmith_api_key
# LANGSMITH_PROJECT=paper-agent
